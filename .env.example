# PCC Platform - Environment Variables
# Copy this file to .env and fill in the values for your environment
# IMPORTANT: Never commit the actual .env file with real credentials

# =====================================================
# Application Environment
# =====================================================
APP_ENV=production                         # Options: development, staging, production
DEBUG=false                                # Enable debug mode (true/false)

# =====================================================
# MongoDB Atlas Configuration
# =====================================================
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pcc?retryWrites=true&w=majority
MONGODB_DB_NAME=pcc                        # Database name
MONGODB_MAX_POOL_SIZE=10                   # Connection pool size per instance

# =====================================================
# Authentication & Security
# =====================================================
JWT_SECRET=change_this_to_a_secure_random_string_at_least_32_chars
JWT_ALGORITHM=HS256                        # JWT signing algorithm
JWT_EXPIRATION=86400                       # Token expiration in seconds (24h)
CORS_ORIGINS=https://app.yourdomain.com    # Comma-separated list of allowed origins

# =====================================================
# Service URLs
# =====================================================
FRONTEND_URL=https://app.yourdomain.com    # Public frontend URL
API_URL=https://api.yourdomain.com         # Public API URL
WORKER_URL=https://worker.yourdomain.com   # Worker service URL (internal)

# =====================================================
# Third-Party Integrations
# =====================================================
# Stripe
STRIPE_SECRET_KEY=sk_live_...              # Stripe live key
STRIPE_WEBHOOK_SECRET=whsec_...            # Webhook signing secret
STRIPE_PUBLISHABLE_KEY=pk_live_...         # Public key for frontend

# OpenAI
OPENAI_API_KEY=sk-...                      # OpenAI API key for AI features
OPENAI_MODEL=gpt-4                         # Model to use for analysis

# SendGrid
SENDGRID_API_KEY=SG....                    # SendGrid API key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com # Default sender email

# Video Integration
DAILY_API_KEY=...                          # Daily.co API key for video sessions

# =====================================================
# GCP Deployment Settings (for deploy-gcp.sh)
# =====================================================
PROJECT_ID=your-gcp-project-id             # GCP project ID
REGION=us-central1                         # GCP region
REPO_NAME=pcc-repo                         # Artifact Registry repository name
SERVICE_ACCOUNT=pcc-runner                 # Service account for Cloud Run
MIN_INSTANCES=0                            # Minimum instances (0 for scale to zero)
MAX_INSTANCES=10                           # Maximum instances
MEMORY=1Gi                                 # Memory allocation
CPU=1                                      # CPU allocation

# =====================================================
# Logging & Monitoring
# =====================================================
LOG_LEVEL=INFO                             # Log level (DEBUG, INFO, WARNING, ERROR)
SENTRY_DSN=https://...@sentry.io/...       # Sentry DSN for error tracking
ENABLE_TELEMETRY=true                      # Enable OpenTelemetry tracing

# =====================================================
# Feature Flags
# =====================================================
ENABLE_AI_FEATURES=true                    # Enable AI-powered features
ENABLE_BILLING=true                        # Enable billing and payments
MAINTENANCE_MODE=false                     # Enable maintenance mode
